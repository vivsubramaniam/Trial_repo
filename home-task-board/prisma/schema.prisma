generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id             String   @id @default(cuid())
  name           String
  photoPath      String?
  lifetimePoints Int      @default(0)  // Total points ever earned (for stats)
  spendablePoints Int     @default(0)  // Current points available to spend
  currentStreak  Int      @default(0)
  streakBonus    Int      @default(1)  // Current bonus (+1 to +7, resets weekly)
  lastActiveDate DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  assignedTasks         Task[]               @relation("AssignedTasks")
  createdTasks          Task[]               @relation("CreatedTasks")
  completions           TaskCompletion[]
  rewardRedemptions     RewardRedemption[]
}

model Task {
  id             String   @id @default(cuid())
  title          String
  points         Int
  recurrence     String   // "daily", "weekly", "once", or specific days like "mon,thu"
  deadline       DateTime?  // Optional deadline, null means no deadline
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  assignedUserId String?
  assignedUser   User?    @relation("AssignedTasks", fields: [assignedUserId], references: [id])
  createdById    String
  createdBy      User     @relation("CreatedTasks", fields: [createdById], references: [id])
  completions    TaskCompletion[]
}

model TaskCompletion {
  id          String   @id @default(cuid())
  completedAt DateTime @default(now())
  basePoints  Int
  bonusPoints Int
  notes       String?

  // Relations
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([completedAt])
  @@index([userId])
}

model Reward {
  id          String   @id @default(cuid())
  name        String
  description String?
  pointsCost  Int      // How many points to redeem this reward
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  // Relations
  redemptions RewardRedemption[]
}

model RewardRedemption {
  id          String   @id @default(cuid())
  redeemedAt  DateTime @default(now())
  pointsSpent Int      // Points spent at time of redemption

  // Relations
  rewardId String
  reward   Reward @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([redeemedAt])
}

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  expenses  Expense[]
}

model PaymentMethod {
  id        String    @id @default(cuid())
  name      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  expenses  Expense[]
}

model Expense {
  id               String          @id @default(cuid())
  date             DateTime
  amount           Float
  description      String
  note             String?
  isSplit          Boolean         @default(false)
  splitPeople      Int?            // Total number of people including you
  splitDetails     String?         // JSON string: [{"name": "John", "percent": 33}, ...]
  mySharePercent   Float?          // Your percentage of the split
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  categoryId       String
  category         ExpenseCategory @relation(fields: [categoryId], references: [id])
  paymentMethodId  String
  paymentMethod    PaymentMethod   @relation(fields: [paymentMethodId], references: [id])

  @@index([date])
  @@index([categoryId])
  @@index([paymentMethodId])
}
